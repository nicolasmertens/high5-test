# 1Test Stripe Environment Variables
# Copy to .env.local for local development
# Set these in Vercel environment variables for production

# Stripe secret key (sk_live_... or sk_test_... for testing)
STRIPE_SECRET_KEY=sk_live_your_key_here

# Stripe price ID for Full Profile ($12 one-time)
STRIPE_PRICE_ID=price_your_price_id_here

# Stripe webhook secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4 Measurement Protocol API Secret (for server-side purchase events)
GA4_API_SECRET=your_ga4_api_secret_here

# Telegram Bot (urgent Founder notifications)
# Create a bot via @BotFather on Telegram to get the token
# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Resend (transactional email)
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_key_here

# Upstash Redis (welcome sequence state)
# Create a Redis database at https://upstash.com or via Vercel integrations
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Welcome cron secret (protects the /api/welcome-cron endpoint)
WELCOME_CRON_SECRET=your_random_secret_here

# Nurture cron secret (protects the /api/nurture-cron endpoint)
NURTURE_CRON_SECRET=your_random_secret_here

# PostHog (server-side analytics tracking)
POSTHOG_API_KEY=phc_your_key_here